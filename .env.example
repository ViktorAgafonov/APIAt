# ===== LLM (OpenAI-совместимый протокол) =====
# ВАЖНО: base_url должен оканчиваться слешем — SDK добавляет относительный путь chat/completions
LLM_BASE_URL=https://ai.wormsoft.ru/api/gpt/
LLM_API_KEY=your-wormsoft-token
LLM_MODEL_NAME=wormsoft/agent/medium

# ===== IMAP (приём писем) =====
IMAP_HOST=imap.example.com
IMAP_PORT=993
IMAP_USER=agent@example.com
IMAP_PASSWORD=changeme
IMAP_FOLDER=INBOX
IMAP_USE_SSL=true

# ===== SMTP (отправка писем) =====
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_USER=agent@example.com
SMTP_PASSWORD=changeme
SMTP_USE_SSL=true
SMTP_FROM=agent@example.com

# ===== Безопасность =====
# Список разрешённых отправителей через запятую
WHITELIST=owner@example.com
# Секретный токен, который должен присутствовать в письме
SECRET_TOKEN=черешня

# ===== Хранилище / рантайм =====
DB_PATH=data/apiat.db
DATA_DIR=data
# Интервал опроса IMAP в режиме --daemon (сек)
POLL_INTERVAL=60
LOG_LEVEL=INFO
